# Rover Swarm Configuration
# Copy to .env and fill in your values

# General
ROVER_SWARM__LOG_LEVEL=INFO
ROVER_SWARM__NODE_ID=rover-01
ROVER_SWARM__MISSION_ID=demo-mission-001

# MQTT
ROVER_SWARM__MQTT__BROKER=localhost
ROVER_SWARM__MQTT__PORT=1883
ROVER_SWARM__MQTT__TLS_ENABLED=false
ROVER_SWARM__MQTT__USERNAME=
ROVER_SWARM__MQTT__PASSWORD=

# gRPC
ROVER_SWARM__GRPC__PORT=50051
ROVER_SWARM__GRPC__TLS_ENABLED=false
ROVER_SWARM__GRPC__MAX_MESSAGE_SIZE=4194304

# Vector Databases
ROVER_SWARM__VECTOR_DB__CHROMA__HOST=localhost
ROVER_SWARM__VECTOR_DB__CHROMA__PORT=8000
ROVER_SWARM__VECTOR_DB__MILVUS__HOST=localhost
ROVER_SWARM__VECTOR_DB__MILVUS__PORT=19530
ROVER_SWARM__VECTOR_DB__QDRANT__HOST=localhost
ROVER_SWARM__VECTOR_DB__QDRANT__PORT=6333
ROVER_SWARM__VECTOR_DB__WEAVIATE__HOST=localhost
ROVER_SWARM__VECTOR_DB__WEAVIATE__PORT=8080

# AI / Model Serving
ROVER_SWARM__AI__OLLAMA__HOST=localhost
ROVER_SWARM__AI__OLLAMA__PORT=11434
ROVER_SWARM__AI__VLLM__HOST=localhost
ROVER_SWARM__AI__VLLM__PORT=8001
ROVER_SWARM__AI__LLAMACPP__MODEL_PATH=/app/models/rover-7b.gguf

# Data / Analytics
ROVER_SWARM__DATA__DUCKDB_PATH=/app/data/telemetry.duckdb
ROVER_SWARM__DATA__ICEBERG__WAREHOUSE=/app/data/iceberg
ROVER_SWARM__DATA__ICEBERG__CATALOG_URI=http://localhost:8181

# Observability
ROVER_SWARM__OTEL__SERVICE_NAME=rover-swarm
ROVER_SWARM__OTEL__EXPORTER_OTLP_ENDPOINT=http://localhost:4317
ROVER_SWARM__PROMETHEUS__PORT=9090

# Web Dashboard
ROVER_SWARM__API__HOST=0.0.0.0
ROVER_SWARM__API__PORT=8080
ROVER_SWARM__API__CORS_ORIGINS=["*"]
ROVER_SWARM__API__JWT_SECRET=change-me-in-production
ROVER_SWARM__API__JWT_ALGORITHM=HS256
ROVER_SWARM__API__ACCESS_TOKEN_EXPIRE_MINUTES=30

# Security
ROVER_SWARM__SECURITY__TLS__ENABLED=true
ROVER_SWARM__SECURITY__TLS__CERT_PATH=/app/certs/rover.crt
ROVER_SWARM__SECURITY__TLS__KEY_PATH=/app/certs/rover.key
ROVER_SWARM__SECURITY__TLS__CA_PATH=/app/certs/ca.crt
ROVER_SWARM__SECURITY__RATE_LIMIT__REQUESTS_PER_MINUTE=60
